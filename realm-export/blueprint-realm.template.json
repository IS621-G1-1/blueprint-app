{
  "realm": "blueprint",
  "enabled": true,
  "displayName": "Blueprint",

  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "sslRequired": "external",

  "passwordPolicy": "length(8) and digits(1) and notUsername",

  "smtpServer": {
    "host": "${SMTP_HOST}",
    "port": "${SMTP_PORT}",
    "from": "${SMTP_FROM_EMAIL}",
    "fromDisplayName": "Blueprint",
    "replyTo": "${SMTP_FROM_EMAIL}",
    "replyToDisplayName": "Blueprint",
    "auth": "${SMTP_AUTH}",
    "user": "${SMTP_USER}",
    "password": "${SMTP_PASSWORD}",
    "starttls": "${SMTP_STARTTLS}",
    "ssl": "false"
  },

  "clients": [
    {
      "clientId": "blueprint-app-frontend",
      "name": "Blueprint Frontend (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-blueprint-app-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "blueprint-app-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "blueprint-app-backend",
      "name": "Blueprint Backend (Bearer-only)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false
    }
  ]
}
