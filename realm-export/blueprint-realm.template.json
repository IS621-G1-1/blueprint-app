{
  "realm": "blueprint",
  "enabled": true,
  "displayName": "Blueprint",

  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "sslRequired": "external",

  "passwordPolicy": "length(8) and digits(1) and notUsername",

  "smtpServer": {
    "host": "${SMTP_HOST}",
    "port": "${SMTP_PORT}",
    "from": "${SMTP_FROM_EMAIL}",
    "fromDisplayName": "Blueprint",
    "replyTo": "${SMTP_FROM_EMAIL}",
    "replyToDisplayName": "Blueprint",
    "auth": "${SMTP_AUTH}",
    "user": "${SMTP_USER}",
    "password": "${SMTP_PASSWORD}",
    "starttls": "${SMTP_STARTTLS}",
    "ssl": "false"
  },

  "clients": [
    {
      "clientId": "blueprint-app-frontend",
      "name": "Blueprint Frontend (SPA — placeholder)",
      "description": "Reserved for future use if the app moves to OIDC redirect flow. Not used today; the backend brokers the password grant via blueprint-app-backend.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "blueprint-app-backend",
      "name": "Blueprint Backend",
      "description": "Confidential client. Three roles: validate inbound JWTs (bearer), broker password grant for /auth/login, and call admin API via service account for user management.",
      "enabled": true,
      "secret": "${BACKEND_CLIENT_SECRET}",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocolMappers": [
        {
          "name": "audience-self",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "blueprint-app-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "service-account-blueprint-app-backend",
      "enabled": true,
      "serviceAccountClientId": "blueprint-app-backend",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users"
        ]
      }
    }
  ]
}
