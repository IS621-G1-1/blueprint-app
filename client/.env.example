# Frontend env. Used when running `npm run dev` outside Docker.
# When running via docker-compose, the build embeds these values via the Dockerfile build args.

VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=blueprint
VITE_KEYCLOAK_CLIENT_ID=blueprint-app-frontend
VITE_API_URL=http://localhost:4000
