# Engineer-facing env. Copy to .env and fill in CHANGE_ME values.
# Never commit .env (gitignored).

# --- Postgres ---
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=CHANGE_ME

# --- JWT signing secret ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# --- Email provider switch ---
# mailpit (default, local)  → Mailpit at http://localhost:8025; no external account needed
# sendgrid                  → SendGrid; requires SENDGRID_API_KEY + SENDGRID_FROM_EMAIL
EMAIL_PROVIDER=mailpit

# Required only when EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Used by Mailpit only (purely cosmetic — Mailpit accepts any sender)
SMTP_FROM_EMAIL=noreply@blueprint.local
