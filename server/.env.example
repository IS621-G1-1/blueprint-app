# Local backend + Docker Postgres.
# The password should match POSTGRES_PASSWORD in the root .env file.
DATABASE_URL=postgresql://blueprint:CHANGE_ME@localhost:5432/blueprint_db
JWT_SECRET=CHANGE_ME

# Email provider: mailpit (local testing) | gmail (live demo)
EMAIL_PROVIDER=mailpit
SMTP_HOST=localhost
SMTP_PORT=1025

# Gmail — only needed when EMAIL_PROVIDER=gmail
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_character_google_app_password
EMAIL_FROM="BlueprInT <yourgmail@gmail.com>"

NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
