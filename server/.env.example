# Backend env. Used when running `npm run dev` outside Docker.
# Inside docker-compose, the service receives env directly from compose.

DATABASE_URL=postgresql://blueprint:CHANGE_ME@localhost:5432/blueprint_app?schema=public
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Keycloak OIDC — backend validates JWTs against the issuer's JWKS.
# Issuer (iss claim) — must match what the browser-facing Keycloak mints (token has this URL)
KEYCLOAK_ISSUER=http://localhost:8080/realms/blueprint
# JWKS fetch URL — what the backend container hits (uses the docker-internal DNS name)
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/blueprint/protocol/openid-connect/certs
# Audience the backend expects on the JWT (set on the bearer-only client)
KEYCLOAK_AUDIENCE=blueprint-app-backend
