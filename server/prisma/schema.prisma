// Blueprint app — own auth (bcrypt + JWT + email OTP). No external IdP.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADVISOR
  ADMIN
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String
  passwordHash    String
  role            Role           @default(STUDENT)
  emailVerifiedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  semesterPlans   SemesterPlan[]

  @@map("users")
}

// In-flight registration. Holds the submitted details + a hashed 6-digit OTP.
// The user row is NOT created until verify succeeds — keeps unverified accounts
// out of the production users table.
model PendingRegistration {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  codeHash     String
  expiresAt    DateTime
  attempts     Int       @default(0)
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@map("pending_registrations")
}

model Module {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  credits        Int
  description    String?
  school         String?
  createdAt      DateTime        @default(now())
  plannedModules PlannedModule[]

  @@map("modules")
}

model SemesterPlan {
  id             String          @id @default(uuid())
  userId         String
  year           Int
  term           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedModules PlannedModule[]

  @@unique([userId, year, term])
  @@map("semester_plans")
}

model PlannedModule {
  id             String       @id @default(uuid())
  semesterPlanId String
  moduleId       String
  createdAt      DateTime     @default(now())
  semesterPlan   SemesterPlan @relation(fields: [semesterPlanId], references: [id], onDelete: Cascade)
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([semesterPlanId, moduleId])
  @@map("planned_modules")
}
